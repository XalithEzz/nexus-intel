# Database
DATABASE_URL="postgresql://nexus:nexus123!@localhost:5432/nexus_intel"
DB_USER=nexus
DB_PASSWORD=nexus123!
DB_NAME=nexus_intel
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-ultra-secure-jwt-secret-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"
DISCORD_CALLBACK_URL="http://localhost:3000/api/auth/discord/callback"

# API Keys for Third-party Services
CENSYS_API_ID="your-censys-api-id"
CENSYS_API_SECRET="your-censys-api-secret"

VIRUSTOTAL_API_KEY="your-virustotal-api-key"

ALIENVALUT_OTX_API_KEY="your-alienvalut-otx-api-key"

SECURITYTRAILS_API_KEY="your-securitytrails-api-key"

URLSCAN_API_KEY="your-urlscan-api-key"

HUNTER_IO_API_KEY="your-hunter-io-api-key"

HAVEIBEENPWNED_API_KEY="your-haveibeenpwned-api-key"

LEAKIX_API_KEY="your-leakix-api-key"

FULLHUNT_API_KEY="your-fullhunt-api-key"

ABUSEIPDB_API_KEY="your-abuseipdb-api-key"

GREYNOISE_API_KEY="your-greynoise-api-key"

THREATMINER_API_KEY="your-threatminer-api-key"

PULSEDIVE_API_KEY="your-pulsedive-api-key"

MALWAREBAZAAR_API_KEY="your-malwarebazaar-api-key"

WHOISXML_API_KEY="your-whoisxml-api-key"

SHODAN_API_KEY="your-shodan-api-key"

ZOOMYE_API_KEY="your-zoomye-api-key"

FOFA_EMAIL="your-fofa-email"
FOFA_API_KEY="your-fofa-api-key"

NETLAS_API_KEY="your-netlas-api-key"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="NEXUS INTEL"
NEXT_PUBLIC_APP_DESCRIPTION="Ultra-modern OSINT Intelligence Platform"

# Environment
NODE_ENV="development"
PORT=3001

# SMTP (optional, for email notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@nexus-intel.com"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# API Credit System
CREDITS_PER_BASIC_SEARCH=1
CREDITS_PER_ADVANCED_SEARCH=5
CREDITS_PER_BULK_SEARCH=20

# Admin
ADMIN_EMAIL="admin@nexus-intel.com"
ADMIN_PASSWORD_HASH="your-hashed-password"
